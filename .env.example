# Copie ce fichier en ".env" et remplis les valeurs.

# Google OAuth (console.cloud.google.com > APIs & Services > Identifiants)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Clé secrète utilisée pour chiffrer les sessions (32 caracteres minimum).
# Génère la tienne avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Adresse de base de l'app en dev (vérifie le port affiché par `npm run dev`, souvent 8080)
APP_ORIGIN=http://localhost:8080
